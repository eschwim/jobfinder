[Unit]
Description=JobFinder job posting poller
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# %h = your home directory; adjust if the repo lives elsewhere
WorkingDirectory=%h/projects/jobfinder
EnvironmentFile=-%h/projects/jobfinder/.env
ExecStart=%h/projects/jobfinder/.venv/bin/python -m jobfinder

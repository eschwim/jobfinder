# Copy to .env and fill in the channels you enabled in config.yaml (notify.channels).

# Pushover (https://pushover.net — create an application to get a token)
PUSHOVER_TOKEN=your-app-token
PUSHOVER_USER=your-user-key

# Email via SMTP. For Gmail, create an app password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
# Optional; both default to SMTP_USER
#EMAIL_FROM=you@gmail.com
#EMAIL_TO=you@gmail.com
